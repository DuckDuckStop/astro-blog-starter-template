---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About ATXPIXEL"
			description="Programmable lighting studio specializing in custom LED system architecture."
		/>
		<style>
			.about-main {
				padding-top: clamp(2.2rem, 7vw, 5rem);
				padding-bottom: clamp(2.8rem, 7vw, 5.5rem);
			}
			.about-shell {
				position: relative;
				max-width: 800px;
				margin: 0;
				padding: clamp(1.2rem, 2vw, 1.8rem) clamp(0.1rem, 1vw, 0.2rem);
				display: grid;
				gap: 2.75rem;
				color: #f2f2f2;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				text-align: left;
				isolation: isolate;
			}
			.about-shell::before {
				content: "";
				position: absolute;
				right: clamp(-4rem, -12vw, -8.4rem);
				top: 0.4rem;
				width: clamp(360px, 56vw, 560px);
				aspect-ratio: 1 / 1;
				border: 1px solid rgba(120, 163, 168, 0.24);
				clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
				opacity: 0.035;
				pointer-events: none;
				z-index: -1;
			}
			.about-shell::after {
				content: "";
				position: absolute;
				right: clamp(-4.4rem, -12vw, -9rem);
				top: 0.2rem;
				width: clamp(360px, 56vw, 560px);
				aspect-ratio: 1 / 1;
				background: none;
				clip-path: none;
				opacity: 0;
				pointer-events: none;
				z-index: -1;
			}
			.about-section {
				display: grid;
				gap: 1.7rem;
			}
			.about-section h1 {
				margin: 0;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-size: clamp(2.2rem, 8vw, 4.1rem);
				font-variation-settings: "wght" 650, "wdth" 110, "opsz" 48;
				letter-spacing: normal;
				line-height: 1.15;
				color: #f2f2f2;
			}
			.about-section .section-heading {
				margin: 0;
				font-size: 1.5rem;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 650, "wdth" 110, "opsz" 48;
				letter-spacing: normal;
				line-height: 1.15;
				color: #ececec;
			}
			.about-section .summary-heading {
				margin-top: 2.4rem;
			}
			.about-section p {
				margin: 0;
				font-size: 1.05rem;
				line-height: 1.6;
				font-variation-settings: "wght" 450, "wdth" 100, "opsz" 18;
				color: #cfcfcf;
			}
			.about-section p + p {
				margin-top: 1.65rem;
			}
			.about-section.intro p + p {
				margin-top: 0.65rem;
			}
			.pillars {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.85rem;
			}
			.pillars li {
				margin: 0;
				padding: 0 0 0 0.9rem;
				position: relative;
				font-size: 0.95rem;
				line-height: 1.6;
				font-variation-settings: "wght" 450, "wdth" 100, "opsz" 16;
				color: #d6d6d6;
			}
			.pillars li::before {
				content: "";
				position: absolute;
				left: 0;
				top: 0.68em;
				width: 2px;
				height: 2px;
				border-radius: 999px;
				background: rgba(120, 163, 168, 0.56);
				transform: translateY(-50%);
			}
			.signature {
				margin-top: 0.45rem;
				display: grid;
				gap: 0.75rem;
			}
			.signature span {
				display: block;
				font-size: 1.4rem;
				line-height: 1.3;
				letter-spacing: 0.02em;
				font-variation-settings: "wght" 600, "wdth" 103, "opsz" 30;
				color: #ececec;
			}
			@media (max-width: 860px) {
				.about-shell {
					max-width: 100%;
					gap: 2.5rem;
				}
				.about-shell::before,
				.about-shell::after {
					right: -3rem;
					width: min(90vw, 440px);
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="about-main">
			<section class="about-shell">
				<section class="about-section intro">
					<h1>About ATXPIXEL</h1>
					<p>
						ATXPIXEL designs and installs custom programmable LED lighting systems.
						Engineered to last. Competitively priced.
					</p>
				</section>

				<section class="about-section">
					<h2 class="section-heading">Our Process</h2>
					<ul class="pillars">
						<li>Electrical load planning.</li>
						<li>Controller selection, for scalable configuration.</li>
						<li>Precision fabrication and routing.</li>
						<li>Thermal and environmental management.</li>
					</ul>
				</section>

				<section class="about-section">
					<h2 class="section-heading">What we deliver</h2>
					<ul class="pillars">
						<li>Easy to use LED systems that adapt.</li>
						<li>DIY control and automated remote management.</li>
						<li>Concierge programming and annual updates.</li>
						<li>Turnkey smart lighting solutions for any budget.</li>
					</ul>
					<h2 class="section-heading summary-heading">In Summary</h2>
					<div class="signature" aria-label="ATXPIXEL signature statement">
						<span>Precise.</span>
						<span>Reliable.</span>
						<span>Built to evolve.</span>
					</div>
				</section>
			</section>
		</main>
		<Footer />
	</body>
</html>
