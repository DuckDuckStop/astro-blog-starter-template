---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About ATXPIXEL"
			description="Programmable lighting studio specializing in custom LED system architecture."
		/>
		<style>
			.about-main {
				padding: 0;
			}
			.about-shell {
				position: relative;
				width: 100%;
				max-width: none;
				margin: 0;
				padding: clamp(1.2rem, 2vw, 1.8rem) clamp(0.1rem, 1vw, 0.2rem);
				overflow: hidden;
				border-radius: 0;
				color: #f2f2f2;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				text-align: left;
				isolation: isolate;
				min-height: 100vh;
			}
			.about-content {
				position: relative;
				z-index: 1;
				display: grid;
				gap: 2.75rem;
				align-content: center;
				min-height: 100vh;
				padding: clamp(1.5rem, 3.5vw, 3.5rem) clamp(1rem, 4vw, 4rem);
				max-width: 980px;
			}
			.about-bg {
				position: absolute;
				inset: 0;
				z-index: -2;
				pointer-events: none;
				background: #070707;
			}
			.about-bg::after {
				content: "";
				position: absolute;
				inset: 0;
				background:
					linear-gradient(145deg, rgba(0, 0, 0, 0.62) 0%, rgba(0, 0, 0, 0.78) 100%),
					radial-gradient(circle at 20% 10%, rgba(255, 255, 255, 0.06), transparent 48%);
			}
			.about-bg-layer {
				position: absolute;
				inset: 0;
				opacity: 0;
				transition: opacity 1200ms ease;
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
			}
			.about-bg-layer.is-active {
				opacity: 1;
			}
			.about-shell::before {
				content: "";
				position: absolute;
				right: clamp(-4rem, -12vw, -8.4rem);
				top: 0.4rem;
				width: clamp(360px, 56vw, 560px);
				aspect-ratio: 1 / 1;
				border: 1px solid rgba(120, 163, 168, 0.24);
				clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
				opacity: 0.035;
				pointer-events: none;
				z-index: -1;
			}
			.about-shell::after {
				content: "";
				position: absolute;
				right: clamp(-4.4rem, -12vw, -9rem);
				top: 0.2rem;
				width: clamp(360px, 56vw, 560px);
				aspect-ratio: 1 / 1;
				background: none;
				clip-path: none;
				opacity: 0;
				pointer-events: none;
				z-index: -1;
			}
			.about-section {
				display: grid;
				gap: 1.7rem;
			}
			.about-section h1 {
				margin: 0;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-size: clamp(2.2rem, 8vw, 4.1rem);
				font-variation-settings: "wght" 650, "wdth" 110, "opsz" 48;
				letter-spacing: normal;
				line-height: 1.15;
				color: #f2f2f2;
			}
			.about-section .section-heading {
				margin: 0;
				font-size: 1.5rem;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 650, "wdth" 110, "opsz" 48;
				letter-spacing: normal;
				line-height: 1.15;
				color: #ececec;
			}
			.about-section .summary-heading {
				margin-top: 2.4rem;
			}
			.about-section p {
				margin: 0;
				font-size: 1.05rem;
				line-height: 1.6;
				font-variation-settings: "wght" 450, "wdth" 100, "opsz" 18;
				color: #cfcfcf;
			}
			.about-section p + p {
				margin-top: 1.65rem;
			}
			.about-section.intro p + p {
				margin-top: 0.65rem;
			}
			.pillars {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.85rem;
			}
			.pillars li {
				margin: 0;
				padding: 0 0 0 0.9rem;
				position: relative;
				font-size: 0.95rem;
				line-height: 1.6;
				font-variation-settings: "wght" 450, "wdth" 100, "opsz" 16;
				color: #d6d6d6;
			}
			.pillars li::before {
				content: "";
				position: absolute;
				left: 0;
				top: 0.68em;
				width: 2px;
				height: 2px;
				border-radius: 999px;
				background: rgba(120, 163, 168, 0.56);
				transform: translateY(-50%);
			}
			.signature {
				margin-top: 0.45rem;
				display: grid;
				gap: 0.75rem;
			}
			.signature span {
				display: block;
				font-size: 1.4rem;
				line-height: 1.3;
				letter-spacing: 0.02em;
				font-variation-settings: "wght" 600, "wdth" 103, "opsz" 30;
				color: #ececec;
			}
			@media (max-width: 860px) {
				.about-main {
					padding-top: clamp(1.2rem, 5vw, 2rem);
					padding-bottom: clamp(1.4rem, 6vw, 2.4rem);
				}
				.about-shell {
					min-height: auto;
					border-radius: 16px;
					padding: clamp(1rem, 3.8vw, 1.4rem);
				}
				.about-content {
					gap: 2.5rem;
					min-height: auto;
					max-width: none;
					padding: 0;
					align-content: start;
				}
				.about-shell::before,
				.about-shell::after {
					right: -3rem;
					width: min(90vw, 440px);
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="about-main">
			<section class="about-shell" data-about-bg-path="/media/about/backgrounds/">
				<div class="about-bg" aria-hidden="true">
					<div class="about-bg-layer is-active"></div>
					<div class="about-bg-layer"></div>
				</div>
				<div class="about-content">
					<section class="about-section intro">
						<h1>About ATXPIXEL</h1>
						<p>
							ATXPIXEL designs and installs custom programmable LED lighting systems.
							Engineered to last. Competitively priced.
						</p>
					</section>

					<section class="about-section">
						<h2 class="section-heading">Our Process</h2>
						<ul class="pillars">
							<li>Electrical planning.</li>
							<li>Component selection.</li>
							<li>Precision fabrication.</li>
							<li>Structured integration.</li>
							<li>Programming and Automation.</li>
						</ul>
					</section>

					<section class="about-section">
						<h2 class="section-heading">What we deliver</h2>
						<ul class="pillars">
							<li>Easy to use LED systems that adapt to any event.</li>
							<li>DIY control and automated remote management.</li>
							<li>Concierge programming and maintenance options.</li>
							<li>Designs that perform and grow with your space.</li>
						</ul>
						<h2 class="section-heading summary-heading">In Summary</h2>
						<div class="signature" aria-label="ATXPIXEL signature statement">
							<span>Precise.</span>
							<span>Reliable.</span>
							<span>Affordable.</span>
						</div>
					</section>
				</div>
			</section>
		</main>
		<Footer />
		<script is:inline>
			(() => {
				const shell = document.querySelector('.about-shell[data-about-bg-path]');
				if (!shell) return;
				const basePath = shell.getAttribute('data-about-bg-path');
				if (!basePath) return;
				const layers = Array.from(shell.querySelectorAll('.about-bg-layer'));
				if (layers.length < 2) return;

				const stems = ['about-01', 'about-02', 'about-03', 'about-04', 'about-05', 'about-06'];
				const extensions = ['jpg', 'jpeg', 'png', 'webp'];
				const candidates = stems.flatMap((stem) =>
					extensions.map((ext) => `${basePath}${stem}.${ext}`)
				);

				const canLoad = (url) =>
					new Promise((resolve) => {
						const img = new Image();
						img.onload = () => resolve(url);
						img.onerror = () => resolve(null);
						img.src = url;
					});

				Promise.all(candidates.map((url) => canLoad(url))).then((result) => {
					const available = result.filter(Boolean);
					if (!available.length) return;

					let imageIndex = 0;
					let activeLayerIndex = 0;
					layers[activeLayerIndex].style.backgroundImage = `url("${available[imageIndex]}")`;
					layers[activeLayerIndex].classList.add('is-active');
					if (available.length === 1) return;

					window.setInterval(() => {
						imageIndex = (imageIndex + 1) % available.length;
						const nextLayerIndex = activeLayerIndex === 0 ? 1 : 0;
						const activeLayer = layers[activeLayerIndex];
						const nextLayer = layers[nextLayerIndex];

						nextLayer.style.backgroundImage = `url("${available[imageIndex]}")`;
						nextLayer.classList.add('is-active');
						activeLayer.classList.remove('is-active');
						activeLayerIndex = nextLayerIndex;
					}, 6500);
				});
			})();
		</script>
	</body>
</html>
