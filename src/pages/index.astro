---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, STOREFRONT_URL } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			@keyframes pulseRedMotif {
				0%,
				100% {
					opacity: 0.06;
				}
				50% {
					opacity: 0.45;
				}
			}
			@keyframes pulseBlueMotif {
				0%,
				100% {
					opacity: 0.06;
				}
				50% {
					opacity: 0.45;
				}
			}
			@keyframes pulseBaseOutline {
				0%,
				100% {
					opacity: 0.34;
				}
				50% {
					opacity: 0.78;
				}
			}
			@keyframes pulseBaseGrid {
				0%,
				100% {
					opacity: 0.3;
				}
				50% {
					opacity: 0.68;
				}
			}
			.welcome-wrap {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				margin: 0;
				padding-left: clamp(1rem, 3vw, 2.5rem);
				padding-right: clamp(1rem, 3vw, 2.5rem);
				padding-top: clamp(2.2rem, 7vw, 5rem);
				padding-bottom: clamp(2.2rem, 7vw, 5rem);
			}
			.hero {
				box-sizing: border-box;
				position: relative;
				overflow: hidden;
				display: grid;
				grid-template-columns: minmax(0, 1.05fr) minmax(220px, 0.75fr);
				gap: clamp(1.4rem, 3vw, 3rem);
				align-items: center;
				border: 1px solid #202020;
				border-radius: 18px;
				padding: clamp(1.5rem, 4vw, 3.6rem);
				background: #0a0a0a;
			}
			.eyebrow {
				font-size: 0.82rem;
				letter-spacing: 0.17em;
				text-transform: uppercase;
				color: #8a8a8a;
				margin-bottom: 0.95rem;
			}
			.hero h1 {
				color: #ededed;
				max-width: 14ch;
				margin-bottom: 1rem;
			}
			.hero-word {
				display: inline-block;
				min-width: 7ch;
				transition: opacity 180ms ease, transform 180ms ease;
			}
			.hero-word.is-swapping {
				opacity: 0;
				transform: translateY(0.2em);
			}
			.subline {
				max-width: 60ch;
				font-size: 1.05rem;
				color: #9a9a9a;
				margin-bottom: 1.8rem;
			}
			.hero-points {
				display: grid;
				gap: 0.4rem;
				margin: 0 0 1.8rem;
				padding: 0;
				list-style: none;
				color: #9a9a9a;
				font-size: 1.05rem;
			}
			.hero-points li {
				white-space: nowrap;
			}
			.audience-signal {
				color: #cecece;
				font-size: 0.95rem;
				line-height: 1.8;
				letter-spacing: 0.045em;
				text-transform: uppercase;
				margin-bottom: 2rem;
			}
			.audience-signal .amp {
				color: #8a8a8a;
				padding: 0 0.2rem;
			}
			.cta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.9rem;
				min-width: 0;
			}
			.cta {
				box-sizing: border-box;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				text-decoration: none;
				font-size: 0.9rem;
				font-weight: 600;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				border-radius: 999px;
				padding: 0.75rem 1.15rem;
				max-width: 100%;
				min-width: 0;
				text-align: center;
			}
			.cta-primary {
				color: #0a0a0a;
				background: #e8e8e8;
				border: 1px solid #e8e8e8;
			}
			.cta-ghost {
				color: #d8d8d8;
				border: 1px solid #3a3a3a;
				background: transparent;
			}
			@media (min-width: 721px) and (hover: hover) {
				.cta-primary:hover,
				.cta-primary:focus-visible {
					background: #ffffff;
					border-color: #ffffff;
					color: #0a0a0a;
					text-shadow: 0 0 8px rgba(0, 240, 255, 0.3);
					box-shadow: 0 0 18px rgba(0, 240, 255, 0.16);
				}
				.cta-ghost:hover,
				.cta-ghost:focus-visible {
					color: #f4feff;
					border-color: var(--accent-cyan);
					background: rgba(255, 255, 255, 0.04);
					text-shadow: 0 0 8px rgba(0, 240, 255, 0.45);
					box-shadow: 0 0 18px rgba(0, 240, 255, 0.12);
				}
			}
			.hero-motif {
				position: absolute;
				inset: 0;
				width: auto;
				height: auto;
				z-index: 0;
				pointer-events: none;
				isolation: isolate;
			}
			.hero-motif-2 {
				position: absolute;
				inset: -120%;
				z-index: 2;
				transform: translate(-10%, -2%) rotate(-22.5deg) scale(4);
				transform-origin: center;
				opacity: 0.45;
				pointer-events: none;
				animation: pulseRedMotif 7.2s ease-in-out infinite;
			}
			.hero-motif-3 {
				position: absolute;
				inset: -120%;
				z-index: 2;
				transform: translate(-10%, -2%) rotate(22.5deg) scale(4);
				transform-origin: center;
				opacity: 0.45;
				pointer-events: none;
				animation: pulseBlueMotif 7.2s ease-in-out 2.1s infinite;
			}
			.hero-motif-2::before {
				content: "";
				position: absolute;
				inset: 14%;
				border: 3px solid rgba(218, 74, 74, 0.38);
				clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
			}
			.hero-motif-2::after {
				content: "";
				position: absolute;
				inset: 14%;
				background:
					radial-gradient(circle, rgba(235, 110, 110, 0.42) 2px, transparent 2.5px) 0 0 / 32px 32px,
					linear-gradient(rgba(218, 86, 86, 0.2) 3px, transparent 3px) 0 0 / 32px 32px,
					linear-gradient(90deg, rgba(218, 86, 86, 0.2) 3px, transparent 3px) 0 0 / 32px 32px;
				clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
			}
			.hero-motif-3::before {
				content: "";
				position: absolute;
				inset: 14%;
				border: 3px solid rgba(88, 144, 235, 0.38);
				clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
			}
			.hero-motif-3::after {
				content: "";
				position: absolute;
				inset: 14%;
				background:
					radial-gradient(circle, rgba(132, 180, 248, 0.42) 2px, transparent 2.5px) 0 0 / 32px 32px,
					linear-gradient(rgba(104, 156, 236, 0.2) 3px, transparent 3px) 0 0 / 32px 32px,
					linear-gradient(90deg, rgba(104, 156, 236, 0.2) 3px, transparent 3px) 0 0 / 32px 32px;
				clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
			}
			.hero-motif::before {
				content: "";
				position: absolute;
				inset: 14%;
				border: 1px solid rgba(190, 190, 190, 0.14);
				clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
				z-index: 1;
				opacity: 0.78;
				animation: pulseBaseOutline 8s ease-in-out infinite;
			}
			.hero-motif::after {
				content: "";
				position: absolute;
				inset: 14%;
				background:
					linear-gradient(rgba(180, 180, 180, 0.04) 1px, transparent 1px) 0 0 / 32px 32px,
					linear-gradient(90deg, rgba(180, 180, 180, 0.04) 1px, transparent 1px) 0 0 / 32px 32px;
				clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
				z-index: 1;
				opacity: 0.68;
				animation: pulseBaseGrid 8s ease-in-out 1.6s infinite;
			}
			@media (max-width: 920px) {
				.hero {
					grid-template-columns: 1fr;
				}
				.hero h1 {
					max-width: none;
				}
				.hero-motif-2 {
					inset: -140%;
				}
				.hero-motif-3 {
					inset: -140%;
				}
			}
			@media (max-width: 720px) {
				.welcome-wrap {
					padding-top: clamp(1.2rem, 5vw, 2rem);
					padding-bottom: clamp(1.4rem, 6vw, 2.4rem);
				}
				.hero {
					border-radius: 16px;
					padding: 1.2rem;
					gap: 1.1rem;
				}
				.hero-points {
					font-size: 0.88rem;
					gap: 0.55rem;
					margin-bottom: 1.25rem;
				}
				.hero-points li {
					white-space: normal;
				}
				.cta-row {
					flex-direction: column;
					align-items: stretch;
				}
				.cta {
					width: 100%;
					padding: 0.85rem 1rem;
					white-space: normal;
				}
				.hero-motif-2,
				.hero-motif-3 {
					inset: -165%;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="welcome-wrap">
			<section class="hero">
				<div style="position: relative; z-index: 3;">
					<h1>
						Trim Lights Built to <span class="hero-word" data-hero-word>Perform</span>
					</h1>
					<ul class="hero-points" aria-label="Key benefits">
						<li>Fully programmed LED lighting designed for your space.</li>
						<li>Secure remote management and automation options.</li>
						<li>Trim light repair and consulting come standard.</li>
					</ul>
					<div class="cta-row">
						<a
							class="cta cta-primary desktop-hover-scan"
							href={STOREFRONT_URL}
							target="_blank"
							rel="noopener noreferrer"
						>
							Visit Storefront &#8599;
						</a>
						<a class="cta cta-ghost desktop-hover-scan" href="/contact">Start Project &#8594;</a>
						<a class="cta cta-ghost desktop-hover-scan" href="/portfolio">View Portfolio &#8594;</a>
					</div>
				</div>
				<div class="hero-motif" aria-hidden="true">
					<div class="hero-motif-2"></div>
					<div class="hero-motif-3"></div>
				</div>
			</section>
		</main>
		<Footer />
		<script is:inline>
			(() => {
				const wordEl = document.querySelector('[data-hero-word]');
				if (!wordEl) return;
				const words = ['Perform', 'Last', 'Impress'];
				let index = 0;

				window.setInterval(() => {
					index = (index + 1) % words.length;
					wordEl.classList.add('is-swapping');
					window.setTimeout(() => {
						wordEl.textContent = words[index];
						wordEl.classList.remove('is-swapping');
					}, 190);
				}, 2600);
			})();
		</script>
	</body>
</html>
