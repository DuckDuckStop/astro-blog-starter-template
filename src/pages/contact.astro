---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.contact-wrap {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				margin: 0;
				padding: clamp(2.2rem, 7vw, 5rem) clamp(1rem, 3vw, 2.5rem);
			}
			.contact-panel {
				box-sizing: border-box;
				position: relative;
				width: 100%;
				max-width: none;
				margin: 0;
				overflow: hidden;
				border: 1px solid #202020;
				border-radius: 18px;
				padding: clamp(1.5rem, 4vw, 3.6rem);
				background: #0a0a0a;
				isolation: isolate;
			}
			.contact-copy {
				position: relative;
				z-index: 1;
				max-width: 980px;
			}
			.contact-eyebrow {
				margin: 0 0 0.5rem;
				font-size: 0.8rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: #8a8a8a;
			}
			.contact-panel::before {
				content: "";
				position: absolute;
				inset: -42%;
				background: url("/blog-placeholder-about.jpg") 72% center / 50% auto no-repeat;
				transform: rotate(-16deg);
				opacity: 0.38;
				pointer-events: none;
				z-index: -2;
			}
			.contact-panel::after {
				content: "";
				position: absolute;
				inset: 0;
				background: linear-gradient(
					135deg,
					rgba(10, 10, 10, 0.78) 0%,
					rgba(10, 10, 10, 0.62) 45%,
					rgba(10, 10, 10, 0.82) 100%
				);
				pointer-events: none;
				z-index: -1;
			}
			.instagram-note {
				max-width: 56ch;
			}
			.instagram-link {
				display: inline-block;
				margin-top: 0.2rem;
			}
			@media (max-width: 720px) {
				.contact-panel {
					border-radius: 16px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="contact-wrap">
			<section class="contact-panel">
				<div class="contact-copy">
					<p class="contact-eyebrow">
						50' single story professional installs start at $3500 plus tax.
						<br />
						Every install includes 3yr parts warranty and basic support.
					</p>
					<h1>Contact</h1>
					<p class="instagram-note">
						Email us at
						<br />
						<a href="mailto:info@atxpixel.com">info@atxpixel.com</a>
						<br />
						<br />
						Follow our passion projects on Instagram.
						<br />
						<a class="instagram-link" href="https://instagram.com/atxpixel" target="_blank" rel="noopener noreferrer">
							instagram.com/atxpixel
						</a>
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
