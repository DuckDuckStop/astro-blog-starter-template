---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, STOREFRONT_URL } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.contact-wrap {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				margin: 0;
				padding: clamp(2.2rem, 7vw, 5rem) clamp(1rem, 3vw, 2.5rem);
			}
			.contact-panel {
				box-sizing: border-box;
				position: relative;
				width: 100%;
				max-width: none;
				margin: 0;
				overflow: hidden;
				border: 1px solid #202020;
				border-radius: 18px;
				padding: clamp(1.5rem, 4vw, 3.6rem);
				background: #0a0a0a;
				isolation: isolate;
			}
			.contact-copy {
				position: relative;
				z-index: 1;
				max-width: 980px;
			}
			.contact-eyebrow {
				margin: 0 0 0.5rem;
				font-size: 0.8rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: #8a8a8a;
			}
			.contact-panel::before {
				content: "";
				position: absolute;
				inset: -42%;
				background: url("/blog-placeholder-about.jpg") 72% center / 50% auto no-repeat;
				transform: rotate(-16deg);
				opacity: 0.38;
				pointer-events: none;
				z-index: -2;
			}
			.contact-panel::after {
				content: "";
				position: absolute;
				inset: 0;
				background: linear-gradient(
					135deg,
					rgba(10, 10, 10, 0.78) 0%,
					rgba(10, 10, 10, 0.62) 45%,
					rgba(10, 10, 10, 0.82) 100%
				);
				pointer-events: none;
				z-index: -1;
			}
			.instagram-note {
				max-width: 56ch;
			}
			.instagram-link {
				display: inline-block;
				margin-top: 0.2rem;
			}
			.contact-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.9rem;
				margin-top: 1.5rem;
			}
			.contact-action {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.8rem 1.1rem;
				border-radius: 999px;
				text-decoration: none;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				font-size: 0.85rem;
				font-weight: 600;
			}
			.contact-action-primary {
				color: #0a0a0a;
				background: #e8e8e8;
				border: 1px solid #e8e8e8;
			}
			.contact-action-secondary {
				color: #d8d8d8;
				background: transparent;
				border: 1px solid #3a3a3a;
			}
			@media (max-width: 720px) {
				.contact-panel {
					border-radius: 16px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="contact-wrap">
			<section class="contact-panel">
				<div class="contact-copy">
					<h1>Contact</h1>
					<p class="instagram-note">
						Start the conversation
						<br />
						<a
							href="#"
							data-obfuscated-link="email"
							aria-label="Email ATX PIXEL"
							rel="nofollow"
						>
							<span data-obfuscated-label="email">Email us</span>
						</a>
						<br />
						<br />
						Follow our micro projects on Instagram.
						<br />
						<a
							class="instagram-link"
							href="#"
							data-obfuscated-link="instagram"
							target="_blank"
							rel="noopener noreferrer nofollow"
							aria-label="Visit ATX PIXEL on Instagram"
						>
							<span data-obfuscated-label="instagram">Instagram</span>
						</a>
					</p>
					<div class="contact-actions">
						<a
							class="contact-action contact-action-primary desktop-hover-scan"
							href={STOREFRONT_URL}
							target="_blank"
							rel="noopener noreferrer"
						>
							Open Storefront &#8599;
						</a>
						<a class="contact-action contact-action-secondary desktop-hover-scan" href="/pricing/">
							View Pricing &#8594;
						</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
		<script is:inline>
			(() => {
				const decode = (codes) => String.fromCharCode(...codes);
				const email = decode([105, 110, 102, 111, 64, 97, 116, 120, 112, 105, 120, 101, 108, 46, 99, 111, 109]);
				const instagramUrl = decode([
					104, 116, 116, 112, 115, 58, 47, 47, 105, 110, 115, 116, 97, 103, 114, 97, 109, 46, 99, 111, 109, 47,
					97, 116, 120, 112, 105, 120, 101, 108,
				]);
				const targets = [
					{
						key: 'email',
						href: `mailto:${email}`,
						label: email,
					},
					{
						key: 'instagram',
						href: instagramUrl,
						label: instagramUrl.replace(/^https?:\/\//, ''),
					},
				];

				for (const target of targets) {
					const link = document.querySelector(`[data-obfuscated-link="${target.key}"]`);
					const label = document.querySelector(`[data-obfuscated-label="${target.key}"]`);
					if (link instanceof HTMLAnchorElement) {
						link.href = target.href;
					}
					if (label instanceof HTMLElement) {
						label.textContent = target.label;
					}
				}
			})();
		</script>
	</body>
</html>
