---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Pricing | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.pricing-wrap {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				margin: 0;
				padding: clamp(2.2rem, 7vw, 5rem) clamp(1rem, 3vw, 2.5rem);
			}
			.pricing-panel {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				border: 1px solid #202020;
				border-radius: 18px;
				padding: clamp(1.5rem, 4vw, 3.6rem);
				background: #0a0a0a;
			}
			.pricing-copy {
				max-width: 980px;
				display: grid;
				gap: 1.1rem;
			}
			.back-link {
				display: inline-block;
				width: fit-content;
			}
			.pricing-copy h1 {
				margin: 0;
				color: #ededed;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 650, "wdth" 110, "opsz" 48;
				line-height: 1.12;
			}
			.pricing-copy p {
				margin: 0;
				max-width: 72ch;
				color: #aaaaaa;
				line-height: 1.7;
			}
			.pricing-note {
				margin: 0;
				padding: 1rem 1.05rem 1rem 1.2rem;
				display: grid;
				gap: 0.9rem;
				border-radius: 14px;
				border: 1px solid rgba(255, 255, 255, 0.08);
				background: rgba(255, 255, 255, 0.02);
			}
			.pricing-note-header {
				display: grid;
				gap: 0.45rem;
				padding-left: 0.2rem;
			}
			.pricing-starting-point {
				margin: 0;
				color: #ededed;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 620, "wdth" 106, "opsz" 28;
				line-height: 1.25;
			}
			.pricing-features {
				margin: 0;
				padding: 0 0 0 1.35rem;
				list-style: disc;
				display: grid;
				gap: 0.9rem;
			}
			.pricing-features li {
				max-width: none;
				color: #aaaaaa;
				line-height: 1.7;
			}
			.pricing-feature-label {
				margin: 0;
				font-size: 0.82rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: #8d8d8d;
			}
			@media (max-width: 720px) {
				.pricing-panel {
					border-radius: 16px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="pricing-wrap">
			<section class="pricing-panel">
				<div class="pricing-copy">
					<a class="back-link" href="/contact/">Back to Contact</a>
					<h1>Pricing</h1>
					<div class="pricing-note">
						<div class="pricing-note-header">
							<p class="pricing-starting-point">50' single-story installs start at $3,500</p>
							<p class="pricing-feature-label">Standard Features Included</p>
						</div>
						<ul class="pricing-features">
							<li>Clean, modular install</li>
							<li>Custom programming</li>
							<li>5-year parts warranty and support</li>
							<li>Simple app control</li>
						</ul>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
