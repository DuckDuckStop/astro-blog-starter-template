---
import BaseHead from '../../../../components/BaseHead.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import {
	getPortfolioPhotoUrl,
	readPortfolioPhotoSubjects,
	type PortfolioPhoto,
	type PortfolioPhotoSubject
} from '../../../../lib/portfolioPhotos';

export async function getStaticPaths() {
	const subjects = await readPortfolioPhotoSubjects();
	return subjects.flatMap((subject) =>
		subject.photos.map((photo) => ({
			params: { subject: subject.slug, photo: photo.slug },
			props: { subject, photo }
		}))
	);
}

const { subject, photo } = Astro.props as { subject: PortfolioPhotoSubject; photo: PortfolioPhoto };
const currentIndex = subject.photos.findIndex((entry) => entry.slug === photo.slug);
const prevPhoto = currentIndex > 0 ? subject.photos[currentIndex - 1] : null;
const nextPhoto =
	currentIndex >= 0 && currentIndex < subject.photos.length - 1
		? subject.photos[currentIndex + 1]
		: null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${photo.caption} | ${subject.label} | ATXPIXEL`}
			description={`Viewing ${photo.caption} in ${subject.label}.`}
			image={getPortfolioPhotoUrl(subject.dirName, photo.fileName)}
		/>
		<style>
			.photo-view {
				display: grid;
				gap: 1rem;
			}
			.photo-header {
				display: grid;
				gap: 0.3rem;
			}
			.back-link {
				display: inline-block;
				margin-bottom: 0.3rem;
			}
			.photo-header p {
				margin: 0;
				color: rgb(var(--gray));
			}
			.photo-frame {
				margin: 0;
				border-radius: 12px;
				overflow: hidden;
				border: 1px solid rgba(255, 255, 255, 0.08);
				background: rgba(10, 10, 10, 0.85);
			}
			.photo-frame img {
				display: block;
				width: 100%;
				height: auto;
				object-fit: contain;
				border-radius: 0;
			}
			.photo-frame figcaption {
				padding: 0.8rem 0.95rem;
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}
			.photo-nav {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.8rem;
			}
			.nav-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.7rem 0.95rem;
				border-radius: 999px;
				text-decoration: none;
				border: 1px solid rgba(255, 255, 255, 0.16);
				background: rgba(10, 10, 10, 0.85);
				color: #d9d9d9;
				text-align: center;
				font-size: 0.88rem;
			}
			.nav-link:focus-visible,
			.nav-link:hover {
				border-color: rgba(255, 255, 255, 0.34);
				color: #f2f2f2;
			}
			.nav-link.disabled {
				opacity: 0.46;
				pointer-events: none;
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="photo-view">
			<section class="photo-header">
				<a class="back-link" href={`/portfolio/photos/${subject.slug}/`}>Back to {subject.label}</a>
				<h1>{subject.label}</h1>
				<p>{photo.caption}</p>
			</section>

			<figure class="photo-frame">
				<img src={getPortfolioPhotoUrl(subject.dirName, photo.fileName)} alt={photo.caption} />
				<figcaption>{photo.caption}</figcaption>
			</figure>

			<nav class="photo-nav" aria-label="Photo navigation">
				<a
					class:list={['nav-link', { disabled: !prevPhoto }]}
					href={prevPhoto ? `/portfolio/photos/${subject.slug}/${prevPhoto.slug}/` : '#'}
				>
					&larr; Previous Photo
				</a>
				<a
					class:list={['nav-link', { disabled: !nextPhoto }]}
					href={nextPhoto ? `/portfolio/photos/${subject.slug}/${nextPhoto.slug}/` : '#'}
				>
					Next Photo &rarr;
				</a>
			</nav>
		</main>
		<Footer />
	</body>
</html>
