---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import {
	getPortfolioPhotoUrl,
	readPortfolioPhotoSubjects,
	type PortfolioPhotoSubject
} from '../../../lib/portfolioPhotos';

export async function getStaticPaths() {
	const subjects = await readPortfolioPhotoSubjects();
	return subjects.map((subject) => ({
		params: { subject: subject.slug },
		props: { subject }
	}));
}

const { subject } = Astro.props as { subject: PortfolioPhotoSubject };
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${subject.label} | ATX PIXEL`}
			description={`Browse ${subject.label.toLowerCase()} portfolio photos.`}
		/>
		<style>
			.portfolio-main {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				margin: 0;
				padding-left: clamp(1rem, 3vw, 2.5rem);
				padding-right: clamp(1rem, 3vw, 2.5rem);
				padding-top: clamp(2.2rem, 7vw, 5rem);
				padding-bottom: clamp(2.4rem, 7vw, 5.2rem);
			}
			.portfolio-shell {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				display: grid;
				gap: clamp(2.2rem, 4vw, 3.4rem);
				border: 1px solid #202020;
				border-radius: 18px;
				padding: clamp(1.5rem, 4vw, 3.6rem);
				background: #0a0a0a;
			}
			.portfolio-copy {
				max-width: 1120px;
				display: grid;
				gap: clamp(2.2rem, 4vw, 3.4rem);
				min-width: 0;
			}
			.subject-header {
				display: grid;
				gap: 0.95rem;
				max-width: 76ch;
			}
			.subject-eyebrow {
				margin: 0;
				font-size: 0.78rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: #8a8a8a;
			}
			.subject-header h1 {
				margin: 0;
				color: #ededed;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 650, "wdth" 110, "opsz" 48;
				line-height: 1.12;
			}
			.photo-list {
				display: grid;
				gap: clamp(2rem, 3.2vw, 3rem);
				padding: 0;
				list-style: none;
			}
			.photo-list li {
				margin: 0;
				min-width: 0;
			}
			.photo-block {
				display: grid;
				grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
				gap: clamp(1.4rem, 2.4vw, 2.2rem);
				align-items: start;
				border-top: 1px solid rgba(255, 255, 255, 0.09);
				padding-top: clamp(1.5rem, 2.6vw, 2.2rem);
				min-width: 0;
			}
			.photo-block.reverse .photo-media {
				order: 2;
			}
			.photo-block.reverse .photo-copy {
				order: 1;
			}
			.photo-media {
				margin: 0;
				min-width: 0;
				border-radius: 10px;
				overflow: hidden;
				background: #111111;
				border: 1px solid rgba(255, 255, 255, 0.1);
				box-shadow: 0 16px 36px rgba(0, 0, 0, 0.3);
			}
			.photo-media img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				aspect-ratio: 16 / 10;
				transition: transform 260ms ease;
			}
			.photo-media img.photo-image-focus {
				object-fit: contain;
				object-position: center;
				transform: scale(1);
				background: #111111;
			}
			.photo-copy {
				display: grid;
				align-content: center;
				gap: 0.72rem;
				padding: 0.2rem 0;
				max-width: 34ch;
				min-width: 0;
			}
			.photo-copy h2 {
				margin: 0;
				font-size: clamp(1.2rem, 1.8vw, 1.55rem);
				line-height: 1.18;
				color: #e7e7e7;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 620, "wdth" 108, "opsz" 36;
				overflow-wrap: anywhere;
			}
			.photo-copy p {
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.7;
				color: #a8a8a8;
				font-variation-settings: "wght" 430, "wdth" 100, "opsz" 18;
				overflow-wrap: anywhere;
			}
			.photo-link {
				display: block;
				text-decoration: none;
			}
			.photo-link:hover img:not(.photo-image-focus) {
				transform: scale(1.02);
			}
			.photo-link:hover img.photo-image-focus {
				transform: scale(1.02);
			}
			.back-link {
				display: inline-block;
				margin-bottom: 0.3rem;
			}
			.subject-subheader {
				max-width: 72ch;
				margin: 0;
				color: #aaaaaa;
				line-height: 1.68;
			}
			.empty-state {
				margin: 0;
				padding: 1rem 0.2rem 0;
				border-top: 1px solid rgba(255, 255, 255, 0.09);
				color: #9d9d9d;
				line-height: 1.68;
			}
			@media (max-width: 720px) {
				.portfolio-main {
					padding-top: clamp(1.2rem, 5vw, 2rem);
					padding-bottom: clamp(1.5rem, 6vw, 2.4rem);
				}
				.portfolio-shell {
					gap: 1.9rem;
					border-radius: 16px;
					padding: 1.2rem;
				}
				.photo-block {
					grid-template-columns: 1fr;
					gap: 1rem;
					padding-top: 1.2rem;
				}
				.photo-block.reverse .photo-media,
				.photo-block.reverse .photo-copy {
					order: initial;
				}
				.photo-media img {
					aspect-ratio: 16 / 9;
				}
				.photo-copy {
					max-width: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="portfolio-main">
			<div class="portfolio-shell">
				<div class="portfolio-copy">
					<section class="subject-header">
						<a class="back-link" href="/portfolio/photos/">Back to all samples</a>
						<p class="subject-eyebrow">Portfolio Category</p>
						<h1>{subject.label}</h1>
						{subject.subheader ? <p class="subject-subheader">{subject.subheader}</p> : null}
					</section>
					{
						subject.photos.length > 0 ? (
							<ul class="photo-list">
								{
									subject.photos.map((photo, index) => (
										<li>
											<article class:list={['photo-block', { reverse: index % 2 === 1 }]}>
												<figure class="photo-media">
													<a class="photo-link" href={`/portfolio/photos/${subject.slug}/${photo.slug}/`}>
														<img
															class:list={[
																'photo-image',
																{ 'photo-image-focus': photo.fileName === 'Christmas Theme.png' }
															]}
															src={getPortfolioPhotoUrl(subject.dirName, photo.fileName)}
															alt={photo.caption}
															loading="lazy"
														/>
													</a>
												</figure>
												<div class="photo-copy">
													<h2>{photo.caption}</h2>
													<p>{photo.description}</p>
												</div>
											</article>
										</li>
									))
								}
							</ul>
						) : (
							<p class="empty-state">Photos for this category are coming soon.</p>
						)
					}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
