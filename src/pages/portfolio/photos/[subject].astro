---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import {
	getPortfolioPhotoUrl,
	readPortfolioPhotoSubjects,
	type PortfolioPhotoSubject
} from '../../../lib/portfolioPhotos';

export async function getStaticPaths() {
	const subjects = await readPortfolioPhotoSubjects();
	return subjects.map((subject) => ({
		params: { subject: subject.slug },
		props: { subject }
	}));
}

const { subject } = Astro.props as { subject: PortfolioPhotoSubject };
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${subject.label} | ATXPIXEL`}
			description={`Browse ${subject.label.toLowerCase()} portfolio photos.`}
		/>
		<style>
			.photo-list {
				display: grid;
				gap: 1rem;
				padding: 0;
				list-style: none;
			}
			.photo-list li {
				margin: 0;
			}
			.photo-block {
				display: grid;
				grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.65fr);
				gap: 1rem;
				align-items: start;
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 12px;
				padding: 0.8rem;
				background: rgba(10, 10, 10, 0.85);
			}
			.photo-block.reverse .photo-media {
				order: 2;
			}
			.photo-block.reverse .photo-copy {
				order: 1;
				text-align: left;
			}
			.photo-media {
				margin: 0;
				border-radius: 10px;
				overflow: hidden;
				background: rgba(255, 255, 255, 0.02);
			}
			.photo-media img {
				display: block;
				width: 100%;
				height: auto;
				object-fit: contain;
				aspect-ratio: 16 / 9;
			}
			.photo-copy {
				display: grid;
				align-content: center;
				gap: 0.6rem;
				padding: 0.25rem 0.2rem;
			}
			.photo-copy h2 {
				margin: 0;
				font-size: 1.1rem;
			}
			.photo-copy p {
				margin: 0;
				font-size: 0.9rem;
				line-height: 1.65;
				color: rgb(var(--gray));
			}
			.photo-link {
				display: block;
				text-decoration: none;
			}
			.back-link {
				display: inline-block;
				margin-bottom: 0.7rem;
			}
			.subject-subheader {
				max-width: 78ch;
				margin: 0.25rem 0 1rem;
				color: rgb(var(--gray));
				line-height: 1.6;
			}
			@media (max-width: 720px) {
				.photo-block {
					grid-template-columns: 1fr;
				}
				.photo-block.reverse .photo-media,
				.photo-block.reverse .photo-copy {
					order: initial;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<a class="back-link" href="/portfolio/photos/">Back to all samples</a>
			<h1>{subject.label}</h1>
			{subject.subheader ? <p class="subject-subheader">{subject.subheader}</p> : null}
			<ul class="photo-list">
				{
					subject.photos.map((photo, index) => (
						<li>
							<article class:list={['photo-block', { reverse: index % 2 === 1 }]}>
								<figure class="photo-media">
									<a class="photo-link" href={`/portfolio/photos/${subject.slug}/${photo.slug}/`}>
										<img
											src={getPortfolioPhotoUrl(subject.dirName, photo.fileName)}
											alt={photo.caption}
											loading="lazy"
										/>
									</a>
								</figure>
								<div class="photo-copy">
									<h2>{photo.caption}</h2>
									<p>{photo.description}</p>
								</div>
							</article>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
