---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Portfolio | ATX PIXEL"
			description="ATX PIXEL project beacon showcasing photography, video, and multidisciplinary demonstrations."
		/>
		<style>
			.portfolio {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				margin: 0;
				padding-left: clamp(1rem, 3vw, 2.5rem);
				padding-right: clamp(1rem, 3vw, 2.5rem);
				padding-top: clamp(2.2rem, 7vw, 5rem);
				padding-bottom: clamp(2.2rem, 7vw, 5rem);
			}
			.portfolio-shell {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				display: grid;
				gap: 1.35rem;
				border: 1px solid #202020;
				border-radius: 18px;
				padding: clamp(1.5rem, 4vw, 3.6rem);
				background: #0a0a0a;
			}
			.portfolio-copy {
				max-width: 980px;
				display: grid;
				gap: 1.35rem;
			}
			.portfolio-eyebrow {
				margin: 0;
				font-size: 0.8rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: #8a8a8a;
			}
			.portfolio h1 {
				margin: 0;
				color: #ededed;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 650, "wdth" 110, "opsz" 48;
				line-height: 1.12;
			}
			.portfolio-description {
				max-width: 72ch;
				margin: 0;
				line-height: 1.7;
				color: #aaaaaa;
			}
			.index-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
			}
			.index-card {
				display: grid;
				gap: 0.8rem;
				padding: 1.2rem;
				border-radius: 16px;
				border: 1px solid rgba(255, 255, 255, 0.1);
				background: rgba(255, 255, 255, 0.02);
			}
			.index-card h2 {
				margin: 0;
				color: #ededed;
				font-size: 1.15rem;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 650, "wdth" 106, "opsz" 36;
			}
			.index-card p {
				margin: 0;
				color: #aaaaaa;
				line-height: 1.65;
			}
			.index-link {
				display: inline-block;
				width: fit-content;
				padding: 0.65rem 1rem;
				border-radius: 999px;
				text-decoration: none;
				border: 1px solid #3a3a3a;
				background: transparent;
				color: #d8d8d8;
				font-size: 0.83rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			@media (min-width: 721px) and (hover: hover) {
				.index-link:hover,
				.index-link:focus-visible {
					color: #f4feff;
					border-color: var(--accent-cyan);
					background: rgba(255, 255, 255, 0.04);
					text-shadow: 0 0 8px rgba(0, 240, 255, 0.45);
					box-shadow: 0 0 18px rgba(0, 240, 255, 0.12);
				}
			}
			@media (max-width: 720px) {
				.portfolio-shell {
					border-radius: 16px;
				}
				.index-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="portfolio">
			<section class="portfolio-shell">
				<div class="portfolio-copy">
					<p class="portfolio-eyebrow">Project Archive</p>
					<h1>Portfolio</h1>
					<p class="portfolio-description">
						A selection of ATX PIXEL installations and concepts. Browse categories and view related
						photos, material options, and project details.
					</p>
					<div class="index-grid">
						<section class="index-card">
							<h2>Project Samples</h2>
							<p>Browse installation categories, example photos, and finished lighting concepts.</p>
							<a class="index-link desktop-hover-scan" href="/portfolio/photos/">Browse Projects</a>
						</section>
						<section class="index-card">
							<h2>Material Selection</h2>
							<p>Review materials and option sets separately from the main project showcase.</p>
							<a class="index-link desktop-hover-scan" href="/portfolio/materials/">Browse Materials</a>
						</section>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
