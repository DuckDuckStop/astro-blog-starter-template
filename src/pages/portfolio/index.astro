---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Portfolio | ATXPIXEL"
			description="ATXPIXEL project beacon showcasing photography, video, and multidisciplinary demonstrations."
		/>
		<style>
			.portfolio {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				margin: 0;
				padding-left: clamp(1rem, 3vw, 2.5rem);
				padding-right: clamp(1rem, 3vw, 2.5rem);
				padding-top: clamp(2.2rem, 7vw, 5rem);
				padding-bottom: clamp(2.2rem, 7vw, 5rem);
			}
			.portfolio-shell {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				display: grid;
				gap: 1.35rem;
				border: 1px solid #202020;
				border-radius: 18px;
				padding: clamp(1.5rem, 4vw, 3.6rem);
				background: #0a0a0a;
			}
			.portfolio-copy {
				max-width: 980px;
				display: grid;
				gap: 1.35rem;
			}
			.portfolio-eyebrow {
				margin: 0;
				font-size: 0.8rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: #8a8a8a;
			}
			.portfolio h1 {
				margin: 0;
				color: #ededed;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 650, "wdth" 110, "opsz" 48;
				line-height: 1.12;
			}
			.portfolio-description {
				max-width: 72ch;
				margin: 0;
				line-height: 1.7;
				color: #aaaaaa;
			}
			.links {
				display: flex;
				gap: 0.8rem;
				flex-wrap: wrap;
			}
			.links a {
				display: inline-block;
				padding: 0.65rem 1rem;
				border-radius: 999px;
				text-decoration: none;
				border: 1px solid #3a3a3a;
				background: transparent;
				color: #d8d8d8;
				font-size: 0.83rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				transition: border-color 160ms ease, color 160ms ease, background-color 160ms ease;
			}
			.links a:hover {
				color: #f0f0f0;
				border-color: #626262;
				background: rgba(255, 255, 255, 0.04);
			}
			@media (max-width: 720px) {
				.portfolio-shell {
					border-radius: 16px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="portfolio">
			<section class="portfolio-shell">
				<div class="portfolio-copy">
					<p class="portfolio-eyebrow">Project Archive</p>
					<h1>Portfolio</h1>
					<p class="portfolio-description">
						A selection of ATXPIXEL installations and concepts. Browse categories and view related
						photos and project details.
					</p>
					<div class="links">
						<a href="/portfolio/photos/">Browse all Categories</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
