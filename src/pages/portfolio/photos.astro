---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { readPortfolioPhotoSubjects } from '../../lib/portfolioPhotos';

let subjects: Array<{ slug: string; label: string; count: number }> = [];
try {
	const loaded = await readPortfolioPhotoSubjects();
	subjects = loaded.map((subject) => ({
		slug: subject.slug,
		label: subject.label,
		count: subject.photos.length
	}));
} catch {
	subjects = [];
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Portfolio Categories | ATXPIXEL"
			description="Browse photo portfolios by subject."
		/>
		<style>
			.portfolio-main {
				padding-top: clamp(2.2rem, 7vw, 5rem);
				padding-bottom: clamp(2.2rem, 7vw, 5rem);
			}
			.portfolio-shell {
				max-width: 960px;
				display: grid;
				gap: 1.25rem;
			}
			.portfolio-eyebrow {
				margin: 0;
				font-size: 0.8rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: #8a8a8a;
			}
			.portfolio-shell h1 {
				margin: 0;
				color: #ededed;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 650, "wdth" 110, "opsz" 48;
				line-height: 1.12;
			}
			.portfolio-subline {
				margin: 0;
				max-width: 68ch;
				color: #aaaaaa;
				line-height: 1.7;
			}
			.subject-grid {
				display: grid;
				gap: 0;
				padding: 0;
				list-style: none;
			}
			.subject-grid li {
				margin: 0;
			}
			.subject-grid a {
				display: grid;
				grid-template-columns: 1fr auto;
				align-items: baseline;
				gap: 1rem;
				border-top: 1px solid rgba(255, 255, 255, 0.09);
				padding: 1.05rem 0.2rem;
				text-decoration: none;
			}
			.subject-grid h2 {
				margin: 0;
				font-size: 1.05rem;
				font-family: "Roboto Flex", system-ui, -apple-system, Segoe UI, Arial, sans-serif;
				font-variation-settings: "wght" 700, "wdth" 106, "opsz" 28;
				font-weight: 700;
				color: #e6e6e6;
			}
			.subject-grid p {
				margin: 0;
				font-size: 0.76rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: #888888;
			}
			.subject-grid a:hover h2 {
				color: #f1f1f1;
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="portfolio-main">
			<section class="portfolio-shell">
				<p class="portfolio-eyebrow">Portfolio Index</p>
				<h1>Category Samples</h1>
				<p class="portfolio-subline">
					Select a category to view project types and details.
				</p>
			{
				subjects.length > 0 ? (
					<ul class="subject-grid">
						{
							subjects.map((subject) => (
								<li>
									<a href={`/portfolio/photos/${subject.slug}/`}>
										<h2>{subject.label}</h2>
										<p>{subject.count} photos</p>
									</a>
								</li>
							))
						}
					</ul>
				) : (
					<p>
						No subject folders with images found yet. Add images under
						<code>public/media/photos/&lt;subject&gt;</code> and refresh.
					</p>
				)
			}
			</section>
		</main>
		<Footer />
	</body>
</html>
