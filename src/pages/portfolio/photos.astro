---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { isMaterialSelectionSubject, readPortfolioPhotoSubjects } from '../../lib/portfolioPhotos';

let subjects: Array<{ slug: string; label: string; count: number }> = [];
try {
	const loaded = await readPortfolioPhotoSubjects();
	subjects = loaded
		.filter((subject) => !isMaterialSelectionSubject(subject))
		.map((subject) => ({
			slug: subject.slug,
			label: subject.label,
			count: subject.photos.length
		}));
} catch {
	subjects = [];
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Portfolio Categories | ATX PIXEL"
			description="Browse photo portfolios by subject."
		/>
		<style>
			.portfolio-main {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				margin: 0;
				padding-left: clamp(1rem, 3vw, 2.5rem);
				padding-right: clamp(1rem, 3vw, 2.5rem);
				padding-top: clamp(2.2rem, 7vw, 5rem);
				padding-bottom: clamp(2.2rem, 7vw, 5rem);
			}
			.portfolio-shell {
				box-sizing: border-box;
				width: 100%;
				max-width: none;
				display: grid;
				gap: 1.25rem;
				border: 1px solid #202020;
				border-radius: 18px;
				padding: clamp(1.5rem, 4vw, 3.6rem);
				background: #0a0a0a;
			}
			.portfolio-copy {
				max-width: 960px;
				display: grid;
				gap: 1.25rem;
				min-width: 0;
			}
			.back-link {
				display: inline-block;
				width: fit-content;
			}
			.portfolio-shell h1 {
				margin: 0;
				color: #ededed;
				font-family: "Space Grotesk", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				font-weight: 650;
				line-height: 1.12;
				overflow-wrap: anywhere;
			}
			.portfolio-subline {
				margin: 0;
				max-width: 68ch;
				color: #aaaaaa;
				line-height: 1.7;
				overflow-wrap: anywhere;
			}
			.channel-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
				padding: 0;
				list-style: none;
			}
			.channel-grid li {
				margin: 0;
				min-width: 0;
			}
			.channel-card {
				box-sizing: border-box;
				display: grid;
				gap: 1.2rem;
				min-height: 100%;
				min-width: 0;
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 18px;
				padding: clamp(1.2rem, 3vw, 1.6rem);
				background:
					radial-gradient(circle at top right, rgba(255, 72, 72, 0.12), transparent 42%),
					linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015));
				text-decoration: none;
			}
			.channel-card:hover {
				border-color: rgba(255, 255, 255, 0.18);
				background:
					radial-gradient(circle at top right, rgba(255, 72, 72, 0.16), transparent 42%),
					linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02));
			}
			.channel-label {
				margin: 0;
				font-size: 0.78rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: #8d8d8d;
				overflow-wrap: anywhere;
			}
			.channel-card h2 {
				margin: 0;
				font-size: clamp(1.35rem, 4vw, 2rem);
				font-family: "Space Grotesk", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				font-weight: 700;
				color: #e6e6e6;
				overflow-wrap: anywhere;
			}
			.channel-card p {
				margin: 0;
				color: #a6a6a6;
				line-height: 1.65;
				overflow-wrap: anywhere;
			}
			.channel-meta {
				display: flex;
				align-items: center;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 1rem;
				min-width: 0;
				padding-top: 0.15rem;
				font-size: 0.8rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: #8b8b8b;
			}
			.channel-count {
				font-size: 0.8rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: #8b8b8b;
				overflow-wrap: anywhere;
			}
			.channel-cta {
				color: #f1c7c7;
				overflow-wrap: anywhere;
			}
			@media (max-width: 720px) {
				.portfolio-shell {
					border-radius: 16px;
				}
				.channel-grid {
					grid-template-columns: 1fr;
				}
				.channel-card {
					gap: 1rem;
					padding: 1.1rem;
				}
				.channel-meta {
					align-items: flex-start;
					gap: 0.45rem 0.9rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="portfolio-main">
			<section class="portfolio-shell">
				<div class="portfolio-copy">
					<a class="back-link" href="/portfolio/">Back to Portfolio</a>
					<h1>Project Samples</h1>
					<p class="portfolio-subline">
						Select a category to view project types and details.
					</p>
				{
						subjects.length > 0 ? (
							<ul class="channel-grid">
								{
									subjects.map((subject) => (
										<li>
											<a class="channel-card" href={`/portfolio/photos/${subject.slug}/`}>
												<p class="channel-label">Project Category</p>
												<h2>{subject.label}</h2>
												<div class="channel-meta">
													<span class="channel-count">{subject.count} photos</span>
													<span class="channel-cta">View Samples</span>
												</div>
											</a>
										</li>
									))
								}
							</ul>
						) : (
						<p>
							No subject folders with images found yet. Add images under
							<code>public/media/photos/&lt;subject&gt;</code> and refresh.
						</p>
					)
				}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
