---
import HeaderLink from './HeaderLink.astro';
import AnimatedLogo from './AnimatedLogo.astro';
import BrandWordmark from './BrandWordmark.astro';
---

<header>
	<nav>
		<h2>
			<a class="brand" href="/">
				<AnimatedLogo />
				<BrandWordmark />
			</a>
		</h2>
		<div class="tabs-carousel" data-tabs-carousel data-swipe-ignore="true">
			<div class="tabs-arrow tabs-arrow-left" data-tabs-arrow="left" aria-hidden="true">
				<span>&larr;</span>
			</div>
			<div class="internal-links" data-tabs-track>
				<HeaderLink href="/">Welcome</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/portfolio">Portfolio</HeaderLink>
				<HeaderLink href="/contact">Contact</HeaderLink>
				<HeaderLink href="/pricing">Pricing</HeaderLink>
			</div>
			<div class="tabs-arrow tabs-arrow-right" data-tabs-arrow="right" aria-hidden="true">
				<span>&rarr;</span>
			</div>
		</div>
	</nav>
</header>
<script is:inline>
	(() => {
		if (!window.matchMedia('(pointer: coarse)').matches) return;

		const normalizePath = (value) => {
			if (!value) return '/';
			const stripped = value.replace(/[?#].*$/, '').replace(/\/+$/, '');
			return stripped || '/';
		};

		const toPathFromUrl = (value) => {
			if (!value) return null;
			try {
				return normalizePath(new URL(value, window.location.origin).pathname);
			} catch {
				return null;
			}
		};

		const goTo = (href) => {
			const targetPath = toPathFromUrl(href);
			if (!targetPath) return false;
			if (targetPath === normalizePath(window.location.pathname)) return false;
			window.location.href = targetPath;
			return true;
		};

		const resolveTarget = (direction) => {
			const path = normalizePath(window.location.pathname);
			const topLevel = ['/', '/about', '/portfolio', '/contact', '/pricing'];

			// /portfolio/photos/:subject/:photo
			if (/^\/portfolio\/photos\/[^/]+\/[^/]+$/.test(path)) {
				const prev = document.querySelector('.photo-nav .nav-link:first-child:not(.disabled)');
				const next = document.querySelector('.photo-nav .nav-link:not(.disabled):last-child');
				const back = document.querySelector('.photo-header .back-link');
				if (direction === 'left') return next?.getAttribute('href') || back?.getAttribute('href');
				return prev?.getAttribute('href') || back?.getAttribute('href');
			}

			// /portfolio/photos/:subject
			if (/^\/portfolio\/photos\/[^/]+$/.test(path)) {
				const firstPhoto = document.querySelector('.photo-list .photo-link');
				const back = document.querySelector('.subject-header .back-link, .back-link');
				if (direction === 'left') return firstPhoto?.getAttribute('href') || '/portfolio/photos/';
				return back?.getAttribute('href') || '/portfolio/photos/';
			}

			// /portfolio/photos
			if (path === '/portfolio/photos') {
				const firstCategory = document.querySelector('.subject-grid a');
				if (direction === 'left') return firstCategory?.getAttribute('href') || '/portfolio';
				return '/portfolio';
			}

			// /portfolio
			if (path === '/portfolio') {
				if (direction === 'left') return '/contact';
				return '/about';
			}

			const topIndex = topLevel.indexOf(path);
			if (topIndex >= 0) {
				if (direction === 'left') return topLevel[topIndex + 1] || null;
				return topLevel[topIndex - 1] || null;
			}

			return null;
		};

		let startX = 0;
		let startY = 0;
		let tracking = false;

		document.addEventListener(
			'touchstart',
			(event) => {
				const target = event.target;
				if (!(target instanceof Element)) return;
				if (target.closest('input, textarea, select, [data-swipe-ignore="true"]')) return;
				const touch = event.changedTouches[0];
				if (!touch) return;
				startX = touch.clientX;
				startY = touch.clientY;
				tracking = true;
			},
			{ passive: true }
		);

		document.addEventListener(
			'touchend',
			(event) => {
				if (!tracking) return;
				tracking = false;
				const touch = event.changedTouches[0];
				if (!touch) return;
				const dx = touch.clientX - startX;
				const dy = touch.clientY - startY;
				if (Math.abs(dx) < 64) return;
				if (Math.abs(dx) < Math.abs(dy) * 1.2) return;
				const direction = dx < 0 ? 'left' : 'right';
				const targetHref = resolveTarget(direction);
				if (targetHref) goTo(targetHref);
			},
			{ passive: true }
		);
	})();

	(() => {
		const initTabsCarousel = () => {
			const carousel = document.querySelector('[data-tabs-carousel]');
			const track = carousel?.querySelector('[data-tabs-track]');
			const leftArrow = carousel?.querySelector('[data-tabs-arrow="left"]');
			const rightArrow = carousel?.querySelector('[data-tabs-arrow="right"]');
			if (!(track instanceof HTMLElement)) return;
			if (track.dataset.carouselInit === 'true') return;
			track.dataset.carouselInit = 'true';

			const updateArrows = () => {
				const maxLeft = Math.max(0, track.scrollWidth - track.clientWidth);
				const left = track.scrollLeft;
				const threshold = 2;
				const showLeft = left > threshold;
				const showRight = left < maxLeft - threshold;
				carousel?.classList.toggle('can-scroll-left', showLeft);
				carousel?.classList.toggle('can-scroll-right', showRight);
				if (leftArrow instanceof HTMLElement) leftArrow.hidden = !showLeft;
				if (rightArrow instanceof HTMLElement) rightArrow.hidden = !showRight;
			};

			const settleToNearestTab = () => {
				if (!window.matchMedia('(max-width: 720px)').matches) return;
				const firstLink = track.querySelector('a');
				const secondLink = firstLink?.nextElementSibling;
				if (!(firstLink instanceof HTMLElement) || !(secondLink instanceof HTMLElement)) return;
				const step = secondLink.offsetLeft - firstLink.offsetLeft;
				if (step <= 0) return;
				const maxLeft = Math.max(0, track.scrollWidth - track.clientWidth);
				const snapped = Math.round(track.scrollLeft / step) * step;
				const targetLeft = Math.max(0, Math.min(maxLeft, snapped));
				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				track.scrollTo({
					left: targetLeft,
					behavior: prefersReducedMotion ? 'auto' : 'smooth',
				});
			};

			const syncToActiveTab = () => {
				if (!window.matchMedia('(max-width: 720px)').matches) return;
				const activeTab = track.querySelector('a.active');
				if (!(activeTab instanceof HTMLElement)) return;
				track.scrollTo({
					left: activeTab.offsetLeft,
					behavior: 'auto',
				});
			};

			syncToActiveTab();
			updateArrows();
			let settleTimer;
			track.addEventListener(
				'scroll',
				() => {
					updateArrows();
					window.clearTimeout(settleTimer);
					settleTimer = window.setTimeout(settleToNearestTab, 90);
				},
				{ passive: true }
			);
			window.addEventListener('resize', updateArrows);
		};

		initTabsCarousel();
		document.addEventListener('astro:page-load', initTabsCarousel);
	})();
</script>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #0a0a0a;
		border-bottom: 1px solid #1c1c1c;
	}
	h2 {
		margin: 0;
		font-size: 1em;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
	}
	.brand :global(.animated-logo) {
		flex: 0 0 auto;
	}
	.brand :global(.brand-wordmark) {
		flex: 0 1 auto;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	nav a {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		box-sizing: border-box;
		padding: 1em 0.5em;
		color: #9a9a9a;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-weight: 500;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		transition:
			color 170ms ease,
			border-bottom-color 170ms ease,
			transform 150ms ease,
			text-shadow 170ms ease;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent-violet);
		color: #ededed;
	}
	@keyframes tab-hover-scan {
		0% {
			transform: translateX(-150%);
		}
		100% {
			transform: translateX(150%);
		}
	}
	@media (min-width: 721px) and (hover: hover) {
		nav a::before {
			content: "";
			position: absolute;
			inset: 0;
			background: linear-gradient(115deg, transparent 0%, rgba(0, 240, 255, 0.22) 46%, transparent 54%);
			transform: translateX(-150%);
			opacity: 0;
			z-index: -1;
			pointer-events: none;
		}
		nav a:hover,
		nav a:focus-visible {
			color: #f4feff;
			border-bottom-color: var(--accent-cyan);
			transform: translateY(-1px);
			text-shadow: 0 0 8px rgba(0, 240, 255, 0.45);
		}
		nav a:hover::before,
		nav a:focus-visible::before {
			opacity: 1;
			animation: tab-hover-scan 420ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
		}
		nav a.active:hover,
		nav a.active:focus-visible {
			border-bottom-color: var(--accent-violet);
			text-shadow: 0 0 8px rgba(154, 77, 255, 0.45);
		}
	}
	.internal-links {
		display: flex;
		gap: 0.3rem;
		flex-wrap: wrap;
	}
	.tabs-carousel {
		display: contents;
	}
	.tabs-arrow {
		display: none;
	}
	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			padding-bottom: 0.6rem;
		}
		.tabs-carousel {
			display: grid;
			align-items: center;
			grid-template-columns: auto minmax(0, 1fr) auto;
			column-gap: 0.35rem;
			width: 100%;
		}
		.tabs-arrow {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 1.4rem;
			color: #8e8e8e;
			font-size: 0.95rem;
			opacity: 0;
			transition: opacity 180ms ease;
		}
		.tabs-carousel.can-scroll-left .tabs-arrow-left,
		.tabs-carousel.can-scroll-right .tabs-arrow-right {
			opacity: 1;
		}
		.internal-links {
			flex-wrap: nowrap;
			display: grid;
			grid-auto-flow: column;
			grid-auto-columns: calc((100% - 0.6rem) / 3);
			overflow-x: auto;
			overscroll-behavior-x: contain;
			scroll-snap-type: x proximity;
			scroll-behavior: smooth;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			gap: 0.3rem;
			padding-bottom: 0.15rem;
		}
		.internal-links::-webkit-scrollbar {
			display: none;
		}
		.internal-links :global(a) {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 100%;
			text-align: center;
			scroll-snap-align: start;
			white-space: nowrap;
			min-width: 0;
			padding: 0.9rem 0.2rem;
			font-size: 0.88rem;
			letter-spacing: 0.02em;
		}
	}
</style>
