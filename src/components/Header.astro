---
import HeaderLink from './HeaderLink.astro';
import AnimatedLogo from './AnimatedLogo.astro';
import BrandWordmark from './BrandWordmark.astro';
import { STOREFRONT_URL } from '../consts';
---

<header>
	<nav>
		<h2>
			<a class="brand" href="/">
				<AnimatedLogo />
				<BrandWordmark />
			</a>
		</h2>
		<div class="tabs-carousel" data-tabs-carousel data-swipe-ignore="true">
			<div class="tabs-arrow tabs-arrow-left" data-tabs-arrow="left" aria-hidden="true">
				<span>&larr;</span>
			</div>
			<div class="internal-links" data-tabs-track>
				<HeaderLink href="/" data-nav-key="welcome">Welcome</HeaderLink>
				<HeaderLink href="/about" data-nav-key="about">About</HeaderLink>
				<HeaderLink href="/portfolio" data-nav-key="portfolio">Portfolio</HeaderLink>
				<HeaderLink href="/contact" data-nav-key="contact">Contact</HeaderLink>
				<HeaderLink href="/pricing" data-nav-key="pricing">Pricing</HeaderLink>
				<HeaderLink
					href={STOREFRONT_URL}
					data-nav-key="store"
					target="_blank"
					rel="noopener noreferrer"
				>
					Shop
				</HeaderLink>
			</div>
			<div class="tabs-arrow tabs-arrow-right" data-tabs-arrow="right" aria-hidden="true">
				<span>&rarr;</span>
			</div>
		</div>
		<a
			class="shop-entry-button"
			href={STOREFRONT_URL}
			target="_blank"
			rel="noopener noreferrer"
			data-shop-entry
			hidden
		>
			Enter Shop
		</a>
	</nav>
</header>
<script is:inline>
	(() => {
		if (!window.matchMedia('(pointer: coarse)').matches) return;

		const normalizePath = (value) => {
			if (!value) return '/';
			const stripped = value.replace(/[?#].*$/, '').replace(/\/+$/, '');
			return stripped || '/';
		};

		const storeHref = document.querySelector('[data-nav-key="store"]')?.getAttribute('href') || '';
		const topLevel = [
			{ key: 'welcome', href: '/' },
			{ key: 'about', href: '/about' },
			{ key: 'portfolio', href: '/portfolio' },
			{ key: 'contact', href: '/contact' },
			{ key: 'pricing', href: '/pricing' },
			{ key: 'store', href: storeHref, external: true },
		];
		const shopEntry = document.querySelector('[data-shop-entry]');
		const tabsTrack = document.querySelector('[data-tabs-track]');
		const topLevelLinks = Array.from(document.querySelectorAll('[data-nav-key]'));
		let selectedTopLevelKey = null;

		const toPathFromUrl = (value) => {
			if (!value) return null;
			try {
				return normalizePath(new URL(value, window.location.origin).pathname);
			} catch {
				return null;
			}
		};

		const getCurrentTopLevelKey = () => {
			const path = normalizePath(window.location.pathname);
			if (path === '/') return 'welcome';
			const match = topLevel.find((entry) => !entry.external && entry.href === path);
			return match?.key || null;
		};

		const syncSelectedTab = () => {
			const currentTopLevelKey = getCurrentTopLevelKey();
			const activeKey = selectedTopLevelKey || currentTopLevelKey;
			for (const link of topLevelLinks) {
				if (!(link instanceof HTMLElement)) continue;
				const isActive = link.dataset.navKey === activeKey;
				link.classList.toggle('active', isActive);
				if (isActive) {
					link.setAttribute('aria-current', 'page');
				} else {
					link.removeAttribute('aria-current');
				}
			}
			if (shopEntry instanceof HTMLElement) {
				const shopSelected = activeKey === 'store';
				shopEntry.hidden = !shopSelected;
			}
			const activeTab = tabsTrack?.querySelector(`[data-nav-key="${activeKey}"]`);
			if (activeTab instanceof HTMLElement && tabsTrack instanceof HTMLElement) {
				tabsTrack.scrollTo({ left: activeTab.offsetLeft, behavior: 'smooth' });
			}
		};

		const goTo = (href) => {
			if (!href) return false;
			const isStorefront = href === storeHref;
			if (isStorefront) {
				selectedTopLevelKey = 'store';
				syncSelectedTab();
				return true;
			}
			const targetPath = toPathFromUrl(href);
			if (!targetPath) return false;
			if (targetPath === normalizePath(window.location.pathname)) {
				selectedTopLevelKey = null;
				syncSelectedTab();
				return false;
			}
			selectedTopLevelKey = null;
			window.location.href = targetPath;
			return true;
		};

		const resolveTarget = (direction) => {
			const path = normalizePath(window.location.pathname);

			// /portfolio/photos/:subject/:photo
			if (/^\/portfolio\/photos\/[^/]+\/[^/]+$/.test(path)) {
				const prev = document.querySelector('.photo-nav .nav-link:first-child:not(.disabled)');
				const next = document.querySelector('.photo-nav .nav-link:not(.disabled):last-child');
				const back = document.querySelector('.photo-header .back-link');
				if (direction === 'left') return next?.getAttribute('href') || back?.getAttribute('href');
				return prev?.getAttribute('href') || back?.getAttribute('href');
			}

			// /portfolio/photos/:subject
			if (/^\/portfolio\/photos\/[^/]+$/.test(path)) {
				const firstPhoto = document.querySelector('.photo-list .photo-link');
				const back = document.querySelector('.subject-header .back-link, .back-link');
				if (direction === 'left') return firstPhoto?.getAttribute('href') || '/portfolio/photos/';
				return back?.getAttribute('href') || '/portfolio/photos/';
			}

			// /portfolio/photos
			if (path === '/portfolio/photos') {
				const firstCategory = document.querySelector('.subject-grid a');
				if (direction === 'left') return firstCategory?.getAttribute('href') || '/portfolio';
				return '/portfolio';
			}

			// /portfolio
			if (path === '/portfolio') {
				if (direction === 'left') return '/contact';
				return '/about';
			}

			const currentTopLevelKey = selectedTopLevelKey || getCurrentTopLevelKey();
			const topIndex = topLevel.findIndex((entry) => entry.key === currentTopLevelKey);
			if (topIndex >= 0) {
				if (direction === 'left') return topLevel[topIndex + 1]?.href || null;
				return topLevel[topIndex - 1]?.href || null;
			}

			return null;
		};

		for (const link of topLevelLinks) {
			if (!(link instanceof HTMLAnchorElement)) continue;
			link.addEventListener('click', (event) => {
				if (link.dataset.navKey !== 'store') {
					selectedTopLevelKey = null;
					return;
				}
				if (!window.matchMedia('(max-width: 720px)').matches) return;
				event.preventDefault();
				selectedTopLevelKey = 'store';
				syncSelectedTab();
			});
		}

		syncSelectedTab();

		let startX = 0;
		let startY = 0;
		let tracking = false;

		document.addEventListener(
			'touchstart',
			(event) => {
				const target = event.target;
				if (!(target instanceof Element)) return;
				if (target.closest('input, textarea, select, [data-swipe-ignore="true"]')) return;
				const touch = event.changedTouches[0];
				if (!touch) return;
				startX = touch.clientX;
				startY = touch.clientY;
				tracking = true;
			},
			{ passive: true }
		);

		document.addEventListener(
			'touchend',
			(event) => {
				if (!tracking) return;
				tracking = false;
				const touch = event.changedTouches[0];
				if (!touch) return;
				const dx = touch.clientX - startX;
				const dy = touch.clientY - startY;
				if (Math.abs(dx) < 64) return;
				if (Math.abs(dx) < Math.abs(dy) * 1.2) return;
				const direction = dx < 0 ? 'left' : 'right';
				const targetHref = resolveTarget(direction);
				if (targetHref) goTo(targetHref);
			},
			{ passive: true }
		);
	})();

	(() => {
		const initTabsCarousel = () => {
			const carousel = document.querySelector('[data-tabs-carousel]');
			const track = carousel?.querySelector('[data-tabs-track]');
			const leftArrow = carousel?.querySelector('[data-tabs-arrow="left"]');
			const rightArrow = carousel?.querySelector('[data-tabs-arrow="right"]');
			if (!(track instanceof HTMLElement)) return;
			if (track.dataset.carouselInit === 'true') return;
			track.dataset.carouselInit = 'true';

			const updateArrows = () => {
				const maxLeft = Math.max(0, track.scrollWidth - track.clientWidth);
				const left = track.scrollLeft;
				const threshold = 2;
				const showLeft = left > threshold;
				const showRight = left < maxLeft - threshold;
				carousel?.classList.toggle('can-scroll-left', showLeft);
				carousel?.classList.toggle('can-scroll-right', showRight);
				if (leftArrow instanceof HTMLElement) leftArrow.hidden = !showLeft;
				if (rightArrow instanceof HTMLElement) rightArrow.hidden = !showRight;
			};

			const settleToNearestTab = () => {
				if (!window.matchMedia('(max-width: 720px)').matches) return;
				const firstLink = track.querySelector('a');
				const secondLink = firstLink?.nextElementSibling;
				if (!(firstLink instanceof HTMLElement) || !(secondLink instanceof HTMLElement)) return;
				const step = secondLink.offsetLeft - firstLink.offsetLeft;
				if (step <= 0) return;
				const maxLeft = Math.max(0, track.scrollWidth - track.clientWidth);
				const snapped = Math.round(track.scrollLeft / step) * step;
				const targetLeft = Math.max(0, Math.min(maxLeft, snapped));
				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				track.scrollTo({
					left: targetLeft,
					behavior: prefersReducedMotion ? 'auto' : 'smooth',
				});
			};

			const syncToActiveTab = () => {
				if (!window.matchMedia('(max-width: 720px)').matches) return;
				const activeTab = track.querySelector('a.active');
				if (!(activeTab instanceof HTMLElement)) return;
				track.scrollTo({
					left: activeTab.offsetLeft,
					behavior: 'auto',
				});
			};

			syncToActiveTab();
			updateArrows();
			let settleTimer;
			track.addEventListener(
				'scroll',
				() => {
					updateArrows();
					window.clearTimeout(settleTimer);
					settleTimer = window.setTimeout(settleToNearestTab, 90);
				},
				{ passive: true }
			);
			window.addEventListener('resize', updateArrows);
		};

		initTabsCarousel();
		document.addEventListener('astro:page-load', initTabsCarousel);
	})();
</script>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #1d1c2a;
		border-bottom: 1px solid #1c1c1c;
	}
	h2 {
		margin: 0;
		font-size: 1em;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
	}
	.brand :global(.animated-logo) {
		flex: 0 0 auto;
	}
	.brand :global(.brand-wordmark) {
		flex: 0 1 auto;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	nav a {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		box-sizing: border-box;
		padding: 1em 0.5em;
		color: #9a9a9a;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-weight: 500;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		transition:
			color 170ms ease,
			border-bottom-color 170ms ease,
			transform 150ms ease,
			text-shadow 170ms ease;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent-violet);
		color: #ededed;
	}
	@keyframes tab-hover-scan {
		0% {
			transform: translateX(-150%);
		}
		100% {
			transform: translateX(150%);
		}
	}
	@media (min-width: 721px) and (hover: hover) {
		nav a::before {
			content: "";
			position: absolute;
			inset: 0;
			background: linear-gradient(115deg, transparent 0%, rgba(0, 240, 255, 0.22) 46%, transparent 54%);
			transform: translateX(-150%);
			opacity: 0;
			z-index: -1;
			pointer-events: none;
		}
		nav a:hover,
		nav a:focus-visible {
			color: #f4feff;
			border-bottom-color: var(--accent-cyan);
			transform: translateY(-1px);
			text-shadow: 0 0 8px rgba(0, 240, 255, 0.45);
		}
		nav a:hover::before,
		nav a:focus-visible::before {
			opacity: 1;
			animation: tab-hover-scan 420ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
		}
		nav a.active:hover,
		nav a.active:focus-visible {
			border-bottom-color: var(--accent-violet);
			text-shadow: 0 0 8px rgba(154, 77, 255, 0.45);
		}
	}
	.internal-links {
		display: flex;
		gap: 0.3rem;
		flex-wrap: wrap;
	}
	.shop-entry-button {
		display: none;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1rem;
		margin-left: auto;
		border: 1px solid var(--accent-cyan);
		border-radius: 999px;
		background:
			linear-gradient(135deg, rgba(0, 240, 255, 0.18), rgba(154, 77, 255, 0.22)),
			rgba(10, 12, 21, 0.92);
		color: #f4feff;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		box-shadow: 0 0 18px rgba(0, 240, 255, 0.16);
	}
	.shop-entry-button:not([hidden]) {
		display: inline-flex;
	}
	.tabs-carousel {
		display: contents;
	}
	.tabs-arrow {
		display: none;
	}
	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			padding-bottom: 0.6rem;
		}
		.shop-entry-button {
			width: 100%;
			margin-top: 0.25rem;
			margin-left: 0;
			padding: 0.55rem 0.9rem;
			font-size: 0.76rem;
			line-height: 1.1;
		}
		.tabs-carousel {
			display: grid;
			align-items: center;
			grid-template-columns: auto minmax(0, 1fr) auto;
			column-gap: 0.35rem;
			width: 100%;
		}
		.tabs-arrow {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 1.4rem;
			color: #8e8e8e;
			font-size: 0.95rem;
			opacity: 0;
			transition: opacity 180ms ease;
		}
		.tabs-carousel.can-scroll-left .tabs-arrow-left,
		.tabs-carousel.can-scroll-right .tabs-arrow-right {
			opacity: 1;
		}
		.internal-links {
			flex-wrap: nowrap;
			display: grid;
			grid-auto-flow: column;
			grid-auto-columns: calc((100% - 0.6rem) / 3);
			overflow-x: auto;
			overscroll-behavior-x: contain;
			scroll-snap-type: x proximity;
			scroll-behavior: smooth;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			gap: 0.3rem;
			padding-bottom: 0.15rem;
		}
		.internal-links::-webkit-scrollbar {
			display: none;
		}
		.internal-links :global(a) {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 100%;
			text-align: center;
			scroll-snap-align: start;
			white-space: nowrap;
			min-width: 0;
			padding: 0.9rem 0.2rem;
			font-size: 0.88rem;
			letter-spacing: 0.02em;
		}
	}
</style>
