---
import { STOREFRONT_URL } from '../consts';

const today = new Date();
---

<footer>
	ATX PIXEL &reg;<br />
	Lighting Engineered Designs<br />
	Austin, Texas<br />
	<br />
	<a href={STOREFRONT_URL} target="_blank" rel="noopener noreferrer">Visit the storefront</a><br />
	<br />
	&copy; {today.getFullYear()} ATX PIXEL LLC. All rights reserved.
</footer>
<style>
	footer {
		padding: 2.2em 1em 3.2em;
		background: #0c1013;
		border-top: 1px solid var(--border-subtle);
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.78rem;
		font-family: "Space Grotesk", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		font-weight: 400;
		letter-spacing: 0.06em;
		text-transform: none;
	}
	footer a {
		color: #edf2f5;
		text-decoration: underline;
		text-decoration-color: rgba(24, 212, 223, 0.5);
		padding-bottom: 0;
	}
	footer a:hover,
	footer a:focus-visible {
		color: var(--accent-cyan);
		text-decoration-color: var(--accent-cyan);
	}
</style>
