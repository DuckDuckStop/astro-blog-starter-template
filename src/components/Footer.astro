---
import { STOREFRONT_URL } from '../consts';

const today = new Date();
---

<footer>
	ATX PIXEL &reg;<br />
	Lighting Engineered Designs<br />
	Austin, Texas<br />
	<br />
	<a href={STOREFRONT_URL} target="_blank" rel="noopener noreferrer">Visit the storefront</a><br />
	<br />
	&copy; {today.getFullYear()} ATX PIXEL LLC. All rights reserved.
</footer>
<style>
	footer {
		padding: 2.5em 1em 4em;
		background: linear-gradient(180deg, rgba(5, 8, 20, 0.2), rgba(5, 8, 20, 0.85)) no-repeat;
		border-top: 1px solid rgba(255, 45, 158, 0.25);
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.78rem;
		font-family: "Space Grotesk", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		font-weight: 500;
		letter-spacing: 0.11em;
		text-transform: uppercase;
	}
	footer a {
		color: #ededed;
		text-decoration: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.18);
		padding-bottom: 0.12rem;
	}
	footer a:hover,
	footer a:focus-visible {
		color: var(--accent-cyan);
		border-bottom-color: var(--accent-cyan);
	}
</style>
